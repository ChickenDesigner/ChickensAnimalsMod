        "caracara_eggs": "1|2|3"
      }
    },
    {
      "apply": {
        "model": "creaturecorner:block/caracara_egg_very_cracked_2"
      },
      "when": {
        "hatch": "2",
        "caracara_eggs": "2|3"
      }
    },
    {
      "apply": {
        "model": "creaturecorner:block/caracara_egg_very_cracked_3"
      },
      "when": {
